# Firebase web config — copy to ".env" for local dev, and set the same keys as
# environment variables in Netlify (Site configuration → Environment variables).
# Find these values in Firebase Console → Project settings → Your apps → SDK setup.
# These are public client keys (safe to expose); access is controlled by Firestore rules.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
